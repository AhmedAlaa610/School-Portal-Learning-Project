@model students_mvc.Models.Student
@{
    ViewData["Title"] = "Add Student";
}
<div class="page-header">
    <div><h1>Add Student</h1><p>Fill in the details to enroll a new student</p></div>
    <a asp-action="Index" class="btn btn-ghost">← Back</a>
</div>
<form asp-action="Create" class="form-card">
    <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:1rem;"></div>
    <div class="form-group">
        <label asp-for="FirstName">First Name</label>
        <input asp-for="FirstName" placeholder="e.g. Ahmed" />
        <span asp-validation-for="FirstName" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="LastName">Last Name</label>
        <input asp-for="LastName" placeholder="e.g. Hassan" />
        <span asp-validation-for="LastName" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Email">Email Address</label>
        <input asp-for="Email" type="email" placeholder="student@email.com" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="DateOfBirth">Date of Birth</label>
        <input asp-for="DateOfBirth" type="date" />
        <span asp-validation-for="DateOfBirth" class="text-danger"></span>
    </div>
    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save Student</button>
        <a asp-action="Index" class="btn btn-ghost">Cancel</a>
    </div>
</form>