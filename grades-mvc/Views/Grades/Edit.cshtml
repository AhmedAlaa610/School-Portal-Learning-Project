@model grades_mvc.Models.Grade
@{
    ViewData["Title"] = "Edit Grade";
}
<div class="page-header">
    <div><h1>Edit Grade</h1><p>Update the grade record</p></div>
    <a asp-action="Index" class="btn btn-ghost">← Back</a>
</div>
<form asp-action="Edit" class="form-card">
    <input type="hidden" asp-for="Id" />
    <div class="form-group">
        <label>Student</label>
        <select asp-for="StudentId" asp-items="ViewBag.Students"></select>
    </div>
    <div class="form-group">
        <label asp-for="CourseName">Course Name</label>
        <input asp-for="CourseName" />
    </div>
    <div class="form-group">
        <label asp-for="Score">Score (0 – 100)</label>
        <input asp-for="Score" type="number" step="0.01" min="0" max="100" />
    </div>
    <div class="form-group">
        <label asp-for="GradeDate">Grade Date</label>
        <input asp-for="GradeDate" type="date" />
    </div>
    <div class="form-group">
        <label asp-for="Notes">Notes (optional)</label>
        <textarea asp-for="Notes"></textarea>
    </div>
    <div class="form-actions">
        <button type="submit" class="btn btn-warn">Update Grade</button>
        <a asp-action="Index" class="btn btn-ghost">Cancel</a>
    </div>
</form>