@model grades_mvc.Models.Grade
@{
    ViewData["Title"] = "Add Grade";
}
<div class="page-header">
    <div><h1>Add Grade</h1><p>Record a new grade for a student</p></div>
    <a asp-action="Index" class="btn btn-ghost">← Back</a>
</div>
<form asp-action="Create" class="form-card">
    <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:1rem;"></div>
    <div class="form-group">
        <label>Student</label>
        <select asp-for="StudentId" asp-items="ViewBag.Students"><option value="">— Select a student —</option></select>
        <span asp-validation-for="StudentId" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="CourseName">Course Name</label>
        <input asp-for="CourseName" placeholder="e.g. Mathematics" />
        <span asp-validation-for="CourseName" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Score">Score (0 – 100)</label>
        <input asp-for="Score" type="number" step="0.01" min="0" max="100" placeholder="e.g. 87.5" />
        <span asp-validation-for="Score" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="GradeDate">Grade Date</label>
        <input asp-for="GradeDate" type="date" />
        <span asp-validation-for="GradeDate" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Notes">Notes (optional)</label>
        <textarea asp-for="Notes" placeholder="Any additional notes..."></textarea>
    </div>
    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save Grade</button>
        <a asp-action="Index" class="btn btn-ghost">Cancel</a>
    </div>
</form>